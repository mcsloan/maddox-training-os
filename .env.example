# Public browser credentials for completed training history.
# Leave blank to use Local Backup Mode.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional public deployment metadata used by the build badge.
# Vercel can automatically expose these system environment variables.
NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA=
NEXT_PUBLIC_VERCEL_ENV=

# Never add a Supabase service-role key to client-side environment variables.
